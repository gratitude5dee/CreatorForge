# Core runtime
CREATORFORGE_DB_PATH=./creatorforge.db
CREATORFORGE_LOG_LEVEL=INFO
CREATORFORGE_TIMEZONE=America/Los_Angeles
PORT=3010

# OpenAI (required)
OPENAI_API_KEY=sk-your-key
OPENAI_TEXT_MODEL=gpt-4o
OPENAI_IMAGE_MODEL=gpt-image-1

# Nevermined x402 (required)
NVM_API_KEY=sandbox:your-api-key
NVM_ENVIRONMENT=sandbox
NVM_PLAN_ID=your-plan-id
NVM_AGENT_ID=your-agent-id
NVM_BASE_URL=http://localhost:3010

# Mindra orchestration (required)
MINDRA_API_URL=https://api.mindra.co/v1/orchestrate
MINDRA_API_KEY=your-mindra-key
MINDRA_TIMEOUT_SECONDS=30

# ZeroClick ads (required)
ZEROCLICK_API_URL=https://api.zeroclick.ai/v1
ZEROCLICK_API_KEY=your-zeroclick-key
ZEROCLICK_TIMEOUT_SECONDS=20

# Procurement policy (locked defaults)
BUDGET_DAILY_CAP=50
BUDGET_VENDOR_CAP=20
APPROVAL_THRESHOLD=10

# Optional buyer identity seed for dynamic pricing examples
DEFAULT_BUYER_ID=anonymous
